# Unique prefix for tunnel subdomains (set per instance, e.g., dev1-, staging-)
# Produces URLs like: {prefix}app-kelvin.eu1.tn.asd.engineer
ENV_PREFIX=

# Supabase credentials are managed by the supabase plugin.
# Run `asd supabase bootstrap` to extract SUPABASE_URL and SUPABASE_ANON_KEY.

# Mollie (test mode)
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOLLIE_WEBHOOK_URL=
